<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="{{ stylesheet | hashUrl }}">
    {% for src in scripts %}
      <script src="{{ src | hashUrl }}" type="module"></script>
    {% endfor %}

    {# Umami analytics #}
    <script defer src="https://cloud.umami.is/script.js" data-website-id="fd878e03-5c0c-4633-bee0-131855510981"></script>

    {# Pagefind search #}
    {% if not isAboutPage %}
      <script src="/pagefind/pagefind-component-ui.js" type="module"></script>
    {% endif %}

    <title>
      {% if title %}
        {{ title }} — {{ site.title }}
      {% else %}
        {{ site.title }}
      {% endif %}
    </title>
    <link rel="canonical" href="{{ baseUrl }}{{ page.url }}">
  </head>

  <body>
    <header class="wrapper">
      {% set headerTag = "h1" if isIndexPage else "h2" %}
      <{{ headerTag }} class="site-header--title">
        <a
          href="/"
          class="site-header--title-link {% if isIndexPage %}site-header--title-link__index-page{% endif %} no-highlight"
        >
          {{- site.title -}}
        </a>
      </{{ headerTag }}>

      {% if not isAboutPage %}
        <p class="tighten">
          {{- site.descriptionHtml | safe }}
          <a href="/about.html" class="site-header--about-link">About this site</a>
        </p>

        <pagefind-config bundle-path="{{ '/pagefind/' | url }}"></pagefind-config>
        <pagefind-searchbox
          placeholder="Search transcripts…"
          hide-shortcut
          show-keyboard-hints=false
        ></pagefind-searchbox>
      {% endif %}
    </header>

    <main>
      {{ content | safe }}
    </main>

    <footer class="site-footer wrapper">
      <nav class="site-footer-nav">
        <a href="#" class="site-footer--top-link no-highlight">Return to top</a>
      </nav>
    </footer>

    {% if isIndexPage %}
      <script type="application/ld+json">
        {{- seriesJsonLd | jsonLdScriptContent | safe -}}
      </script>
    {% elif episode %}
      {% for block in episode.jsonLd %}
        <script type="application/ld+json">
          {{- block | jsonLdScriptContent | safe -}}
        </script>
      {% endfor %}
    {% endif %}
  </body>
</html>

---
layout: base.njk
stylesheet: /css/index.css
isIndexPage: true
eagerImageCount: 5
---
{% from "macros/episodeMeta.njk" import episodeMeta %}

<ul class="episode-list wrapper">
  {%- for item in collections.episode | reverse %}
    {%- set episode = item.data.episode %}
    <li class="episode-card {% if episode.supplement.isInterlude %} episode-card__interlude {% endif %}">
      <a
        href="{{ item.url }}"
        class="episode-card--thumb-link no-highlight"
      >
        <img
          src="{% imageUrl episode.imagePath, 300 %}"
          alt="Episode {{ episode.episodeNumber }}"
          class="episode-card--thumb"
          loading="{% if loop.index <= eagerImageCount %}eager{% else %}lazy{% endif %}"
        >
      </a>

      <header class="episode-card--header">
        <h2 class="episode-card--heading">
          <a
            href="{{ item.url }}"
            class="episode-card--title-link no-highlight"
          >
            <span class="episode-card--episode-number c-episode-number">#{{ episode.episodeNumber }}</span>
            <span class="episode-card--title">{{ episode.rss.title }}</span
          </a>
        </h2>

        <p class="episode-card--description">
          {{- episode.rss.description -}}
        </p>

        <p class="episode-card--meta c-episode-meta">
          {{- episodeMeta(episode) -}}
        </p>
      </header>
    </li>
  {%- endfor %}
</ul>

---
layout: base.njk
scripts:
  - /js/timeline.js
  - /js/miniplayer.js
pagination:
  data: episodes
  size: 1
  alias: episode
  addAllPagesToCollections: true
permalink: "{{ episode.url }}"
tags: episode
eleventyComputed:
  title: "{{ episode.episodeNumber }}. {{ episode.title }}"
---
{% from "macros/episodeMeta.njk" import episodeMeta %}

<article class="episode">
  <header>
    {% if episode.youtube %}
      <div class="js-video-sentinel">
        <iframe
          class="episode--video js-video"
          src="https://www.youtube-nocookie.com/embed/{{ episode.youtube | youtubeId }}"
          title="Episode {{ episode.episodeNumber }}"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
    {% else %}
      <img
        src="{% imageUrl episode.imagePath, 1000 %}"
        alt="Episode {{ episode.episodeNumber }}"
        class="episode--image"
      >
    {% endif %}

    <h1 class="episode--title wrapper">
      <span class="c-episode-number">#{{ episode.episodeNumber }}</span>
      {{ episode.title }}
    </h1>
    <p class="wrapper">
      {{- episode.description -}}
    </p>

    <p class="episode--meta c-episode-meta wrapper">
      {{- episodeMeta(episode) -}}
    </p>
  </header>

  <div class="episode--content wrapper">
    <p class="episode--content-warning">All content below have been AI generated.</p>

    <section class="episode--summary">
      <h2>Summary</h2>
      <p>{{ episode.summary }}</p>
    </section>

    {%- if episode.sections.length > 0 %}
      <nav>
        <h2>Table of Contents</h2>
        <ol class="episode--toc">
          {%- for section in episode.sections %}
            <li>
              <a href="#section-{{ section.title | slug }}">
                {{- section.title -}}
              </a>
            </li>
          {%- endfor %}
        </ol>
      </nav>
    {%- endif %}

    <hr>

    <section class="episode--transcript" data-transcript>
      {%- for segment in episode.segments %}
        {%- for section in episode.sections %}
          {%- if section.segmentIndex == segment.id %}
            <h2 class="section-title" id="section-{{ section.title | slug }}">
              {{- loop.index }}. {{ section.title -}}
            </h2>
          {%- endif %}
        {%- endfor %}
        {%- if segment.timelineMarker %}
          <time class="timeline-marker" data-time="{{ segment.start }}">
            {{- segment.start | formatRoundedTimecode -}}
          </time>
        {%- endif %}
        <span data-start="{{ segment.start }}" data-end="{{ segment.end }}">{{ segment.text }}</span>
      {%- endfor %}
    </section>
  </div>
</article>

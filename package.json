{
  "name": "roaming-holiday-podcast-transcriptions",
  "author": "DM Kishi <dm.kishi@gmail.com>",
  "version": "1.0.0",
  "type": "module",
  "imports": {
    "#lib/*": "./lib/*"
  },
  "scripts": {
    "transcribe": "node bin/transcribe-episodes.ts",
    "www:dev": "eleventy --serve --incremental",
    "www:build": "eleventy && pagefind --site www/dist",
    "www:deploy": "pnpm www:build && node bin/deploy-www.ts",
    "upload-cloudflare": "node --env-file=.env bin/upload-cloudflare.ts",
    "check": "pnpm typecheck && pnpm lint && pnpm test",
    "typecheck": "tsc --noEmit && tsc --noEmit -p www/tsconfig.json",
    "lint": "pnpm lint:js && pnpm lint:css",
    "lint:css": "pnpm exec stylelint 'www/src/css/*.css'",
    "lint:js": "oxlint",
    "test": "vitest run",
    "fallow": "fallow"
  },
  "packageManager": "pnpm@11.10.0",
  "dependencies": {
    "@11ty/eleventy": "^3.1.6",
    "@11ty/eleventy-img": "^6.0.4",
    "@dmkishi/css-reset": "^1.3.1",
    "@dmkishi/oxlintrc": "^0.3.0",
    "@dmkishi/stylelint-config": "^0.0.0",
    "@js-temporal/polyfill": "^0.5.1",
    "@types/gh-pages": "^6.1.0",
    "@types/minimist": "^1.2.5",
    "@types/node": "^25.9.4",
    "@types/youtube": "^0.2.0",
    "cssnano": "^7.1.9",
    "esbuild": "^0.27.7",
    "fast-xml-parser": "^5.9.3",
    "gh-pages": "^6.3.0",
    "html-minifier-terser": "^7.2.0",
    "minimist": "^1.2.8",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "pagefind": "^1.5.2",
    "picocolors": "^1.1.1",
    "postcss": "^8.5.16",
    "postcss-import": "^16.1.1",
    "postcss-preset-env": "^11.3.2",
    "stylelint": "^17.14.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  }
}

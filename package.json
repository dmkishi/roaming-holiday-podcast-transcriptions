{
  "name": "roaming-holiday-podcast-transcriptions",
  "author": "DM Kishi <dm.kishi@gmail.com>",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "transcribe": "tsx --env-file=.env bin/transcribe.ts",
    "site:build": "tsx bin/build-site.ts && eleventy",
    "site:build:data-only": "tsx bin/build-site.ts",
    "site:dev": "open http://localhost:8080 & eleventy --serve",
    "check": "pnpm typecheck && pnpm lint && pnpm test && pnpm fallow",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "test": "vitest run",
    "fallow": "fallow"
  },
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@dmkishi/css-reset": "^1.2.2",
    "@dmkishi/markdownlint-cli2.yaml": "^0.0.3",
    "@js-temporal/polyfill": "^0.5.1",
    "@types/minimist": "^1.2.5",
    "@types/node": "^25.5.2",
    "fast-xml-parser": "^5.5.10",
    "minimist": "^1.2.8",
    "openai": "^6.33.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.19.0",
    "picocolors": "^1.1.1",
    "postcss": "^8.5.8",
    "postcss-import": "^16.1.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
}

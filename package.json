{
  "name": "roaming-holiday-podcast-transcriptions",
  "author": "DM Kishi <dm.kishi@gmail.com>",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "transcribe": "tsx bin/transcribe-episodes.ts",
    "upload-cloudflare": "tsx --env-file=.env bin/upload-cloudflare.ts",
    "build-www": "tsx bin/build-www.ts && eleventy",
    "dev-www": "open http://localhost:8080 & eleventy --serve",
    "check": "pnpm typecheck && pnpm lint && pnpm test",
    "typecheck": "tsc --noEmit && tsc --noEmit -p www/tsconfig.json",
    "lint": "oxlint",
    "test": "vitest run",
    "fallow": "fallow"
  },
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@11ty/eleventy-img": "^6.0.4",
    "@dmkishi/css-reset": "^1.3.1",
    "@dmkishi/markdownlint-cli2.yaml": "^0.0.3",
    "@dmkishi/oxlintrc": "^0.3.0",
    "@js-temporal/polyfill": "^0.5.1",
    "@types/minimist": "^1.2.5",
    "@types/node": "^25.6.0",
    "@types/youtube": "^0.2.0",
    "cssnano": "^7.1.9",
    "esbuild": "^0.27.7",
    "fast-xml-parser": "^5.7.3",
    "html-minifier-terser": "^7.2.0",
    "minimist": "^1.2.8",
    "oxlint": "^1.66.0",
    "oxlint-tsgolint": "^0.23.0",
    "picocolors": "^1.1.1",
    "postcss": "^8.5.14",
    "postcss-import": "^16.1.1",
    "postcss-preset-env": "^11.2.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "yaml": "^2.8.4",
    "zod": "^4.4.3"
  }
}
